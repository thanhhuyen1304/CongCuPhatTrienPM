# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/ecommerce

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_2024_change_this_in_production_12345
JWT_EXPIRE=15m
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key_2024_change_this_in_production_67890
JWT_REFRESH_EXPIRE=7d

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Application URLs
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Cloudinary Configuration (if using image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret